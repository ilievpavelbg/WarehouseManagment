@model WarehouseManagment.Models.Wms.InventoryByLocationViewModel

@{
    ViewData["Title"] = "Inventory by Location";
}

<h2 class="mb-3">Наличност по зони</h2>

@if (!Model.Rows.Any())
{
    <div class="alert alert-info">Няма наличност в момента.</div>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Warehouse</th>
                <th>Zone</th>
                <th>Location</th>
                <th>Item SKU</th>
                <th>Item</th>
                <th class="text-end">Quantity</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.Warehouse</td>
                    <td>@row.Zone</td>
                    <td>@row.Location</td>
                    <td>@row.ItemSku</td>
                    <td>@row.ItemName</td>
                    <td class="text-end">@row.Quantity</td>
                </tr>
            }
        </tbody>
    </table>
}
