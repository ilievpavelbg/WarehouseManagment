@model List<MaterialCategory>

@{
    ViewData["Title"] = "Категории материали";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="MaterialCategory" asp-action="Create">Нова категория</a>
</div>

@if (!Model.Any())
{
    <p>Няма създадени категории материали.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Код</th>
                <th>Име</th>
                <th>Описание</th>
                <th>Активна</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td>@category.Code</td>
                    <td>@category.Name</td>
                    <td>@category.Description</td>
                    <td>@(category.IsActive ? "Да" : "Не")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="MaterialCategory" asp-action="Edit" asp-route-id="@category.Id">Редакция</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}