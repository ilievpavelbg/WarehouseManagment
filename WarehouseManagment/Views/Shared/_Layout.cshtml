<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - V E T E I D A -</title>
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WarehouseManagment.styles.css" asp-append-version="true" />
</head>
<body>
    @Html.AntiForgeryToken()
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var salesControllers = new[] { "Product", "Sale", "Courier" };
        var wmsControllers = new[] { "Warehouse", "WarehouseSettings", "Material", "StockInquiry", "LowStock", "InventoryMovement", "AuditLog" };
        var masterDataControllers = new[] { "MaterialCategory", "UnitOfMeasure", "Supplier" };
        var isHomeActive = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase);
        var isSalesActive = salesControllers.Contains(currentController);
        var isWmsActive = wmsControllers.Contains(currentController);
        var isMasterDataActive = masterDataControllers.Contains(currentController);
    }
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand rounded" asp-controller="Home" asp-action="Index" style="background-color:#ff0000; padding:8px;">Управление склад VETEIDA</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between" id="navbarColor01">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0 flex-nowrap">
                            <li class="nav-item">
                                <a class="nav-link @(isHomeActive ? "active" : string.Empty)" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isSalesActive ? "active" : string.Empty)" href="#" id="salesDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Продажби
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="salesDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Product" asp-action="Index">Артикули</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Sale" asp-action="BarcodeScanerInput">Магазин</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Sale" asp-action="AllSales">Отчет магазин</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Courier" asp-action="BarcodeScanerInput">Куриер</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Courier" asp-action="AllCouriers">Отчет куриери</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isWmsActive ? "active" : string.Empty)" href="#" id="wmsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Склад
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="wmsDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index">WMS табло</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Warehouse" asp-action="Index">Складове</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="WarehouseSettings" asp-action="Index">Настройки складове</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Material" asp-action="Index">Материали</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="StockInquiry" asp-action="Index">Наличности</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="LowStock" asp-action="Index">Под минимум</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="InventoryMovement" asp-action="Index">Движения склад</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AuditLog" asp-action="Index">Одит лог</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(isMasterDataActive ? "active" : string.Empty)" href="#" id="masterDataDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Номенклатури
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="masterDataDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="MaterialCategory" asp-action="Index">Категории материали</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="UnitOfMeasure" asp-action="Index">Мерни единици</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Supplier" asp-action="Index">Доставчици</a></li>
                                </ul>
                            </li>
                        </ul>
                    }
                    <div class="ms-auto">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="bg-light text-center text-lg-start fixed-bottom">
        <div class="text-center p-3">
            &copy; 2023 - Warehouse Managment VETEIDA - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="https://www.google.com/recaptcha/api.js?onload=onloadCallback&render=explicit"
            async defer>
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $.ajaxSetup({
            beforeSend: function (xhr, settings) {
                var token = $('input[name="__RequestVerificationToken"]').first().val();
                var method = settings.type || settings.method || 'GET';

                if (token && !/^(GET|HEAD|OPTIONS|TRACE)$/i.test(method)) {
                    xhr.setRequestHeader('RequestVerificationToken', token);
                }
            }
        });
    </script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>