@model MaterialStockCardModel

@{
    ViewData["Title"] = "Картон на материал";
    var previousPage = Math.Max(1, Model.Filter.Page - 1);
    var nextPage = Math.Min(Model.TotalMovementPages, Model.Filter.Page + 1);
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="card mb-3">
    <div class="card-header">Материал</div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3 mb-2"><strong>Код:</strong> @Model.MaterialCode</div>
            <div class="col-md-3 mb-2"><strong>Име:</strong> @Model.MaterialName</div>
            <div class="col-md-3 mb-2"><strong>Категория:</strong> @Model.CategoryName</div>
            <div class="col-md-3 mb-2"><strong>Мерна единица:</strong> @Model.UnitOfMeasureName</div>
            <div class="col-md-3 mb-2"><strong>Доставчик:</strong> @Model.SupplierName</div>
            <div class="col-md-3 mb-2"><strong>Обща наличност:</strong> @Model.TotalCurrentStock.ToString("N4")</div>
            <div class="col-md-3 mb-2"><strong>Минимална наличност:</strong> @Model.MinimumStock.ToString("N4")</div>
            <div class="col-md-3 mb-2"><strong>Статус:</strong> <span class="badge @Model.StatusCssClass">@Model.StatusName</span></div>
            <div class="col-md-3 mb-2"><strong>Стандартна цена:</strong> @Model.StandardCost.ToString("N4")</div>
            <div class="col-md-3 mb-2"><strong>Активен:</strong> @(Model.IsActive ? "Да" : "Не")</div>
        </div>
    </div>
</div>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Material" asp-action="Receive" asp-route-id="@Model.MaterialId">Приемане</a>
    <a class="btn btn-outline-primary" asp-controller="Material" asp-action="Transfer" asp-route-id="@Model.MaterialId">Преместване</a>
    <a class="btn btn-outline-secondary" asp-controller="Material" asp-action="AdjustStock" asp-route-id="@Model.MaterialId">Корекция наличност</a>
    <a class="btn btn-secondary" asp-controller="Material" asp-action="Index">Назад към материали</a>
</div>

<div class="card mb-3">
    <div class="card-header">Текущи складови позиции</div>
    <div class="card-body">
        @if (!Model.Positions.Any())
        {
            <p>Няма текущи складови позиции.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Склад</th>
                            <th>Локация</th>
                            <th>Партида</th>
                            <th>Lot номер</th>
                            <th>Количество</th>
                            <th>Последна промяна</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var position in Model.Positions)
                        {
                            <tr>
                                <td>@position.WarehouseName</td>
                                <td>@position.LocationName</td>
                                <td>@position.BatchNumber</td>
                                <td>@position.LotNumber</td>
                                <td>@position.Quantity.ToString("N4")</td>
                                <td>@position.LastUpdatedOn.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><span class="badge @position.StatusCssClass">@position.StatusName</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">Наличност по склад</div>
    <div class="card-body">
        @if (!Model.StockByWarehouse.Any())
        {
            <p>Няма наличност по склад.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Склад</th>
                            <th>Количество</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var warehouseStock in Model.StockByWarehouse)
                        {
                            <tr>
                                <td>@warehouseStock.WarehouseName</td>
                                <td>@warehouseStock.Quantity.ToString("N4")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">История на движенията</div>
    <div class="card-body">
        <form asp-controller="MaterialStockCard" asp-action="Index" asp-route-id="@Model.MaterialId" method="get" class="mb-3">
            <div class="row align-items-end">
                <div class="col-md-2 mb-2">
                    <label for="DateFrom" class="form-label">От дата</label>
                    <input id="DateFrom" name="DateFrom" type="date" value="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2 mb-2">
                    <label for="DateTo" class="form-label">До дата</label>
                    <input id="DateTo" name="DateTo" type="date" value="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label for="WarehouseId" class="form-label">Склад</label>
                    <select id="WarehouseId" name="WarehouseId" class="form-control">
                        <option value="">Всички</option>
                        @foreach (var warehouse in Model.Warehouses)
                        {
                            <option value="@warehouse.Id" selected="@(Model.Filter.WarehouseId == warehouse.Id)">@warehouse.Code - @warehouse.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 mb-2">
                    <label for="MovementType" class="form-label">Тип движение</label>
                    <select id="MovementType" name="MovementType" class="form-control">
                        <option value="">Всички</option>
                        @foreach (MovementType movementType in Enum.GetValues(typeof(MovementType)))
                        {
                            <option value="@movementType" selected="@(Model.Filter.MovementType == movementType)">@movementType</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 mb-2">
                    <label for="BatchOrLot" class="form-label">Партида / Lot</label>
                    <input id="BatchOrLot" name="BatchOrLot" value="@Model.Filter.BatchOrLot" class="form-control" />
                </div>
            </div>
            <div class="row align-items-end">
                <div class="col-md-2 mb-2">
                    <label for="PageSize" class="form-label">Редове</label>
                    <select id="PageSize" name="PageSize" class="form-control">
                        <option value="25" selected="@(Model.Filter.PageSize == 25)">25</option>
                        <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                        <option value="100" selected="@(Model.Filter.PageSize == 100)">100</option>
                    </select>
                </div>
                <div class="col-md-10 mb-2">
                    <input type="hidden" name="Page" value="1" />
                    <button type="submit" class="btn btn-primary">Филтрирай</button>
                    <a class="btn btn-outline-secondary" asp-controller="MaterialStockCard" asp-action="Index" asp-route-id="@Model.MaterialId">Изчисти</a>
                </div>
            </div>
        </form>

        @if (!Model.Movements.Any())
        {
            <p>Няма намерени движения.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Дата</th>
                            <th>Тип движение</th>
                            <th>Количество</th>
                            <th>Склад</th>
                            <th>Локация</th>
                            <th>Склад получател</th>
                            <th>Локация получател</th>
                            <th>Партида</th>
                            <th>Lot</th>
                            <th>Референция</th>
                            <th>Документ</th>
                            <th>Потребител</th>
                            <th>Бележки</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var movement in Model.Movements)
                        {
                            <tr>
                                <td>@movement.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                <td><span class="badge @movement.MovementTypeCssClass">@movement.MovementTypeName</span></td>
                                <td>@movement.Quantity.ToString("+0.####;-0.####;0")</td>
                                <td>@movement.WarehouseName</td>
                                <td>@movement.WarehouseLocationName</td>
                                <td>@movement.DestinationWarehouseName</td>
                                <td>@movement.DestinationWarehouseLocationName</td>
                                <td>@movement.BatchNumber</td>
                                <td>@movement.LotNumber</td>
                                <td>@movement.ReferenceType</td>
                                <td>@movement.ReferenceNumber</td>
                                <td>@movement.User</td>
                                <td>@movement.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <div>Общо движения: @Model.TotalMovementItems</div>
                <div>
                    <a class="btn btn-sm btn-outline-secondary @(Model.Filter.Page <= 1 ? "disabled" : string.Empty)"
                       asp-controller="MaterialStockCard"
                       asp-action="Index"
                       asp-route-id="@Model.MaterialId"
                       asp-route-Page="@previousPage"
                       asp-route-PageSize="@Model.Filter.PageSize"
                       asp-route-DateFrom="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-DateTo="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")"
                       asp-route-WarehouseId="@Model.Filter.WarehouseId"
                       asp-route-MovementType="@Model.Filter.MovementType"
                       asp-route-BatchOrLot="@Model.Filter.BatchOrLot">Назад</a>
                    <span class="mx-2">Страница @Model.Filter.Page от @Model.TotalMovementPages</span>
                    <a class="btn btn-sm btn-outline-secondary @(Model.Filter.Page >= Model.TotalMovementPages ? "disabled" : string.Empty)"
                       asp-controller="MaterialStockCard"
                       asp-action="Index"
                       asp-route-id="@Model.MaterialId"
                       asp-route-Page="@nextPage"
                       asp-route-PageSize="@Model.Filter.PageSize"
                       asp-route-DateFrom="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-DateTo="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")"
                       asp-route-WarehouseId="@Model.Filter.WarehouseId"
                       asp-route-MovementType="@Model.Filter.MovementType"
                       asp-route-BatchOrLot="@Model.Filter.BatchOrLot">Напред</a>
                </div>
            </div>
        }
    </div>
</div>