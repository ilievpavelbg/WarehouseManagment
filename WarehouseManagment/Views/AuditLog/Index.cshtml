@model AuditLogIndexModel

@{
    ViewData["Title"] = "Одит лог";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="alert alert-info">
    Достъпът до този екран ще бъде ограничен до Admin / Warehouse Manager при предстоящата задача за роли.
</div>

<form method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-md-2">
            <label asp-for="Filter.DateFrom" class="form-label">Дата от</label>
            <input asp-for="Filter.DateFrom" name="DateFrom" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.DateTo" class="form-label">Дата до</label>
            <input asp-for="Filter.DateTo" name="DateTo" type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.User" class="form-label">Потребител</label>
            <input asp-for="Filter.User" name="User" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.ActionType" class="form-label">Действие</label>
            <select asp-for="Filter.ActionType" name="ActionType" class="form-control">
                <option value="">Всички</option>
                @foreach (var actionType in Model.ActionTypes)
                {
                    <option value="@actionType">@GetActionLabel(actionType)</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.EntityType" class="form-label">Обект</label>
            <select asp-for="Filter.EntityType" name="EntityType" class="form-control">
                <option value="">Всички</option>
                @foreach (var entityType in Model.EntityTypes)
                {
                    <option value="@entityType">@entityType</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Filter.DocumentNumber" class="form-label">Документ</label>
            <input asp-for="Filter.DocumentNumber" name="DocumentNumber" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Филтрирай</button>
        <a class="btn btn-secondary" asp-action="Index">Изчисти</a>
    </div>
</form>

<table class="table table-striped table-sm align-middle">
    <thead>
        <tr>
            <th>Дата</th>
            <th>Потребител</th>
            <th>Действие</th>
            <th>Тип обект</th>
            <th>Обект / документ</th>
            <th>Описание</th>
            <th>IP адрес</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.CreatedOn.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@log.UserName</td>
                <td>@log.ActionTypeName</td>
                <td>@log.EntityType</td>
                <td>@log.EntityDocument</td>
                <td>@log.Description</td>
                <td>@log.IpAddress</td>
                <td>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@log.Id">Детайли</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Logs.Any())
{
    <div class="alert alert-warning">Няма намерени записи.</div>
}

<nav aria-label="Audit log pagination">
    <ul class="pagination">
        @for (var page = 1; page <= Model.TotalPages; page++)
        {
            <li class="page-item @(page == Model.Filter.Page ? "active" : string.Empty)">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-DateFrom="@Model.Filter.DateFrom?.ToString("yyyy-MM-dd")"
                   asp-route-DateTo="@Model.Filter.DateTo?.ToString("yyyy-MM-dd")"
                   asp-route-User="@Model.Filter.User"
                   asp-route-ActionType="@Model.Filter.ActionType"
                   asp-route-EntityType="@Model.Filter.EntityType"
                   asp-route-DocumentNumber="@Model.Filter.DocumentNumber"
                   asp-route-Page="@page"
                   asp-route-PageSize="@Model.Filter.PageSize">@page</a>
            </li>
        }
    </ul>
</nav>

@functions {
    private static string GetActionLabel(AuditActionType actionType)
    {
        return actionType switch
        {
            AuditActionType.Create => "Създаване",
            AuditActionType.Update => "Редакция",
            AuditActionType.Delete => "Изтриване",
            AuditActionType.Receive => "Приемане",
            AuditActionType.Transfer => "Преместване",
            AuditActionType.Adjustment => "Корекция",
            AuditActionType.SettingsChange => "Промяна настройки",
            AuditActionType.Import => "Импорт",
            AuditActionType.Login => "Вход",
            AuditActionType.Logout => "Изход",
            _ => actionType.ToString()
        };
    }
}