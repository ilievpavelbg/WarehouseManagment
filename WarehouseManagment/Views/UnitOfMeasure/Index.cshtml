@model List<UnitOfMeasure>

@{
    ViewData["Title"] = "Мерни единици";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="UnitOfMeasure" asp-action="Create">Нова мерна единица</a>
</div>

@if (!Model.Any())
{
    <p>Няма създадени мерни единици.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Код</th>
                <th>Име</th>
                <th>Символ</th>
                <th>Активна</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var unit in Model)
            {
                <tr>
                    <td>@unit.Code</td>
                    <td>@unit.Name</td>
                    <td>@unit.Symbol</td>
                    <td>@(unit.IsActive ? "Да" : "Не")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="UnitOfMeasure" asp-action="Edit" asp-route-id="@unit.Id">Редакция</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}