@model MaterialTransferModel

@{
    ViewData["Title"] = "Преместване на материал";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="alert alert-secondary">
    <div><strong>Материал:</strong> @Model.MaterialCode - @Model.MaterialName</div>
    <div><strong>Обща наличност:</strong> @Model.CurrentTotalStock.ToString("N4") @Model.UnitOfMeasureName</div>
</div>

<form asp-controller="Material" asp-action="Transfer" method="post">
    <input asp-for="MaterialId" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <h4>От</h4>
    <div class="row">
        <div class="col-md-12 mb-3">
            <label asp-for="SourceMaterialStockId" class="form-label">Наличност източник</label>
            <select asp-for="SourceMaterialStockId" class="form-control">
                <option value="">Избери наличност</option>
                @foreach (var stock in Model.SourceStockPositions)
                {
                    var locationLabel = stock.WarehouseLocation == null
                        ? "Без локация"
                        : $"{stock.WarehouseLocation.Code} - {stock.WarehouseLocation.Name}";
                    var batchLabel = stock.MaterialBatch == null
                        ? "Без партида"
                        : string.IsNullOrWhiteSpace(stock.MaterialBatch.LotNumber)
                            ? $"Партида {stock.MaterialBatch.BatchNumber}"
                            : $"Партида {stock.MaterialBatch.BatchNumber} / Lot {stock.MaterialBatch.LotNumber}";
                    var quantityLabel = stock.Quantity.ToString("N4");
                    <option value="@stock.Id">@stock.Warehouse.Code - @stock.Warehouse.Name / @locationLabel / @batchLabel / Наличност @quantityLabel @Model.UnitOfMeasureName</option>
                }
            </select>
            <span asp-validation-for="SourceMaterialStockId" class="text-danger"></span>
            <div class="form-text">Показани са само реални складови позиции с наличност по-голяма от нула.</div>
        </div>
    </div>

    <h4>Към</h4>
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="DestinationWarehouseId" class="form-label">Склад получател</label>
            <select asp-for="DestinationWarehouseId" class="form-control">
                <option value="">Избери</option>
                @foreach (var warehouse in Model.Warehouses)
                {
                    <option value="@warehouse.Id">@warehouse.Code - @warehouse.Name</option>
                }
            </select>
            <span asp-validation-for="DestinationWarehouseId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DestinationWarehouseLocationId" class="form-label">Локация получател</label>
            <select asp-for="DestinationWarehouseLocationId" class="form-control">
                <option value="">Без локация</option>
                @foreach (var location in Model.WarehouseLocations)
                {
                    <option value="@location.Id">@location.Warehouse.Code - @location.Code - @location.Name</option>
                }
            </select>
            <span asp-validation-for="DestinationWarehouseLocationId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Quantity" class="form-label">Количество (@Model.UnitOfMeasureName)</label>
            <input asp-for="Quantity" class="form-control" />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>
        <div class="col-md-8 mb-3">
            <label asp-for="Notes" class="form-label">Бележки</label>
            <textarea asp-for="Notes" class="form-control"></textarea>
            <span asp-validation-for="Notes" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Премести</button>
    <a class="btn btn-secondary" asp-controller="Material" asp-action="Index">Отказ</a>
</form>