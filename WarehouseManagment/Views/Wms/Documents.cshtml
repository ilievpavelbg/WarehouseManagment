@model WarehouseManagment.Models.Wms.DocumentsListViewModel

@{
    ViewData["Title"] = "Receipts & Shipments";
}

<h2 class="mb-3">Receipts</h2>

@if (!Model.Receipts.Any())
{
    <div class="alert alert-info">No purchase receipts yet.</div>
}
else
{
    <table class="table table-striped table-sm mb-4">
        <thead>
            <tr>
                <th>Number</th>
                <th>Warehouse</th>
                <th>Status</th>
                <th>Created</th>
                <th>Posted</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var receipt in Model.Receipts)
            {
                <tr>
                    <td>@receipt.DocumentNumber</td>
                    <td>@receipt.Warehouse.Name</td>
                    <td>@receipt.Status</td>
                    <td>@receipt.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>@receipt.PostedAt?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}

<h2 class="mb-3">Shipments</h2>

@if (!Model.Shipments.Any())
{
    <div class="alert alert-info">No shipments yet.</div>
}
else
{
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Number</th>
                <th>Warehouse</th>
                <th>Status</th>
                <th>Created</th>
                <th>Posted</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var shipment in Model.Shipments)
            {
                <tr>
                    <td>@shipment.DocumentNumber</td>
                    <td>@shipment.Warehouse.Name</td>
                    <td>@shipment.Status</td>
                    <td>@shipment.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>@shipment.PostedAt?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}
