@model List<Warehouse>

@{
    ViewData["Title"] = "Складове и локации";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Warehouse" asp-action="Create">Нов склад</a>
</div>

@if (!Model.Any())
{
    <p>Няма създадени складове.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Код</th>
                <th>Име</th>
                <th>Зони</th>
                <th>Локации</th>
                <th>Активен</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var warehouse in Model)
            {
                <tr>
                    <td>@warehouse.Code</td>
                    <td>@warehouse.Name</td>
                    <td>@warehouse.Zones.Count</td>
                    <td>@warehouse.Locations.Count</td>
                    <td>@(warehouse.IsActive ? "Да" : "Не")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Warehouse" asp-action="CreateZone" asp-route-warehouseId="@warehouse.Id">Добави зона</a>
                        <a class="btn btn-sm btn-outline-success" asp-controller="Warehouse" asp-action="CreateLocation" asp-route-warehouseId="@warehouse.Id">Добави локация</a>
                    </td>
                </tr>
                @if (warehouse.Zones.Any() || warehouse.Locations.Any())
                {
                    <tr>
                        <td colspan="6">
                            <div class="row">
                                <div class="col-md-6">
                                    <strong>Зони</strong>
                                    <ul>
                                        @foreach (var zone in warehouse.Zones.OrderBy(x => x.Code))
                                        {
                                            <li>@zone.Code - @zone.Name</li>
                                        }
                                    </ul>
                                </div>
                                <div class="col-md-6">
                                    <strong>Локации</strong>
                                    <ul>
                                        @foreach (var location in warehouse.Locations.OrderBy(x => x.Code))
                                        {
                                            <li>@location.Code - @location.Name</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}
