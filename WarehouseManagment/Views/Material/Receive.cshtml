@model GoodsReceiptModel

@{
    ViewData["Title"] = "Приемане на материали";
    var selectedBatch = Model.MaterialBatches.FirstOrDefault(x => x.Id == Model.MaterialBatchId);
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="alert alert-secondary">
    <div><strong>Материал:</strong> @Model.MaterialCode - @Model.MaterialName</div>
</div>

<form asp-controller="Material" asp-action="Receive" method="post">
    <input asp-for="MaterialId" type="hidden" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="WarehouseId" class="form-label">Склад</label>
            <select asp-for="WarehouseId" class="form-control">
                <option value="">Избери</option>
                @foreach (var warehouse in Model.Warehouses)
                {
                    <option value="@warehouse.Id">@warehouse.Code - @warehouse.Name</option>
                }
            </select>
            <span asp-validation-for="WarehouseId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="WarehouseLocationId" class="form-label">Локация</label>
            <select asp-for="WarehouseLocationId" class="form-control">
                <option value="">Без локация</option>
                @foreach (var location in Model.WarehouseLocations)
                {
                    <option value="@location.Id">@location.Warehouse.Code - @location.Code - @location.Name</option>
                }
            </select>
            <span asp-validation-for="WarehouseLocationId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="BatchSelection" class="form-label">Партида</label>
            <select asp-for="BatchSelection" id="batchSelection" class="form-control">
                <option value="">Без партида</option>
                @foreach (var batch in Model.MaterialBatches)
                {
                    var batchLabel = string.IsNullOrWhiteSpace(batch.LotNumber)
                        ? batch.BatchNumber
                        : $"{batch.BatchNumber} / {batch.LotNumber}";
                    <option value="@batch.Id" data-lot="@batch.LotNumber">@batchLabel</option>
                }
                <option value="new">Нова партида</option>
            </select>
            <span asp-validation-for="BatchSelection" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3 existing-batch-info">
            <label class="form-label">Lot номер</label>
            <input id="existingLotNumber" value="@selectedBatch?.LotNumber" class="form-control" readonly />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="ReceivedQuantity" class="form-label">Получено количество (@Model.UnitOfMeasureName)</label>
            <input asp-for="ReceivedQuantity" class="form-control" />
            <span asp-validation-for="ReceivedQuantity" class="text-danger"></span>
        </div>
    </div>

    <div id="newBatchFields" class="border rounded p-3 mb-3">
        <h5>Нова партида</h5>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="BatchNumber" class="form-label">Номер партида</label>
                <input asp-for="BatchNumber" class="form-control" />
                <span asp-validation-for="BatchNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="LotNumber" class="form-label">Lot номер</label>
                <input asp-for="LotNumber" class="form-control" />
                <span asp-validation-for="LotNumber" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="SupplierId" class="form-label">Доставчик</label>
            <select asp-for="SupplierId" class="form-control">
                <option value="">Без доставчик</option>
                @foreach (var supplier in Model.Suppliers)
                {
                    <option value="@supplier.Id">@supplier.Name</option>
                }
            </select>
            <span asp-validation-for="SupplierId" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DocumentNumber" class="form-label">Документ номер</label>
            <input asp-for="DocumentNumber" class="form-control" />
            <span asp-validation-for="DocumentNumber" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Бележки</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Приеми</button>
    <a class="btn btn-secondary" asp-controller="Material" asp-action="Index">Отказ</a>
</form>

@section Scripts {
    <script>
        (function () {
            const batchSelection = document.getElementById('batchSelection');
            const newBatchFields = document.getElementById('newBatchFields');
            const existingBatchInfo = document.querySelector('.existing-batch-info');
            const existingLotNumber = document.getElementById('existingLotNumber');

            function updateBatchFields() {
                const selectedOption = batchSelection.options[batchSelection.selectedIndex];
                const isNewBatch = batchSelection.value === 'new';
                const hasExistingBatch = batchSelection.value && !isNewBatch;

                newBatchFields.style.display = isNewBatch ? '' : 'none';
                existingBatchInfo.style.display = hasExistingBatch ? '' : 'none';
                existingLotNumber.value = hasExistingBatch ? (selectedOption.getAttribute('data-lot') || '') : '';
            }

            batchSelection.addEventListener('change', updateBatchFields);
            updateBatchFields();
        })();
    </script>
}