@model StockInquiryIndexModel

@{
    ViewData["Title"] = "Наличности";
    var previousPage = Math.Max(1, Model.Filter.Page - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.Filter.Page + 1);
}

<h1 class="text-center">@ViewData["Title"]</h1>

<form asp-controller="StockInquiry" asp-action="Index" method="get" class="mb-3">
    <div class="row align-items-end">
        <div class="col-md-3 mb-2">
            <label for="MaterialId" class="form-label">Материал</label>
            <select id="MaterialId" name="MaterialId" class="form-control">
                <option value="">Всички</option>
                @foreach (var material in Model.Materials)
                {
                    <option value="@material.Id" selected="@(Model.Filter.MaterialId == material.Id)">@material.Code - @material.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label for="MaterialCategoryId" class="form-label">Категория</label>
            <select id="MaterialCategoryId" name="MaterialCategoryId" class="form-control">
                <option value="">Всички</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id" selected="@(Model.Filter.MaterialCategoryId == category.Id)">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label for="SupplierId" class="form-label">Доставчик</label>
            <select id="SupplierId" name="SupplierId" class="form-control">
                <option value="">Всички</option>
                @foreach (var supplier in Model.Suppliers)
                {
                    <option value="@supplier.Id" selected="@(Model.Filter.SupplierId == supplier.Id)">@supplier.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label for="BatchOrLot" class="form-label">Партида / Lot</label>
            <input id="BatchOrLot" name="BatchOrLot" value="@Model.Filter.BatchOrLot" class="form-control" />
        </div>
    </div>

    <div class="row align-items-end">
        <div class="col-md-3 mb-2">
            <label for="WarehouseId" class="form-label">Склад</label>
            <select id="WarehouseId" name="WarehouseId" class="form-control">
                <option value="">Всички</option>
                @foreach (var warehouse in Model.Warehouses)
                {
                    <option value="@warehouse.Id" selected="@(Model.Filter.WarehouseId == warehouse.Id)">@warehouse.Code - @warehouse.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label for="WarehouseLocationId" class="form-label">Локация</label>
            <select id="WarehouseLocationId" name="WarehouseLocationId" class="form-control">
                <option value="">Всички</option>
                @foreach (var location in Model.WarehouseLocations)
                {
                    <option value="@location.Id" selected="@(Model.Filter.WarehouseLocationId == location.Id)">@location.Warehouse.Code - @location.Code - @location.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2 mb-2">
            <label for="PageSize" class="form-label">Редове</label>
            <select id="PageSize" name="PageSize" class="form-control">
                <option value="25" selected="@(Model.Filter.PageSize == 25)">25</option>
                <option value="50" selected="@(Model.Filter.PageSize == 50)">50</option>
                <option value="100" selected="@(Model.Filter.PageSize == 100)">100</option>
            </select>
        </div>
        <div class="col-md-2 mb-2">
            <div class="form-check">
                <input id="LowStockOnly" name="LowStockOnly" value="true" type="checkbox" checked="@Model.Filter.LowStockOnly" class="form-check-input" />
                <label for="LowStockOnly" class="form-check-label">Под минимум</label>
            </div>
        </div>
        <div class="col-md-2 mb-2">
            <div class="form-check">
                <input id="ZeroStockOnly" name="ZeroStockOnly" value="true" type="checkbox" checked="@Model.Filter.ZeroStockOnly" class="form-check-input" />
                <label for="ZeroStockOnly" class="form-check-label">Нулева наличност</label>
            </div>
        </div>
    </div>

    <div class="row align-items-end">
        <div class="col-md-3 mb-2">
            <div class="form-check">
                <input id="ActiveMaterialsOnly" name="ActiveMaterialsOnly" value="true" type="checkbox" checked="@Model.Filter.ActiveMaterialsOnly" class="form-check-input" />
                <label for="ActiveMaterialsOnly" class="form-check-label">Само активни материали</label>
            </div>
        </div>
        <div class="col-md-9 mb-2">
            <input type="hidden" name="Page" value="1" />
            <button type="submit" class="btn btn-primary">Филтрирай</button>
            <a class="btn btn-outline-secondary" asp-controller="StockInquiry" asp-action="Index">Изчисти</a>
            <a class="btn btn-success"
               asp-controller="StockInquiry"
               asp-action="Export"
               asp-route-MaterialId="@Model.Filter.MaterialId"
               asp-route-MaterialCategoryId="@Model.Filter.MaterialCategoryId"
               asp-route-SupplierId="@Model.Filter.SupplierId"
               asp-route-WarehouseId="@Model.Filter.WarehouseId"
               asp-route-WarehouseLocationId="@Model.Filter.WarehouseLocationId"
               asp-route-BatchOrLot="@Model.Filter.BatchOrLot"
               asp-route-LowStockOnly="@Model.Filter.LowStockOnly"
               asp-route-ZeroStockOnly="@Model.Filter.ZeroStockOnly"
               asp-route-ActiveMaterialsOnly="@Model.Filter.ActiveMaterialsOnly">Excel</a>
        </div>
    </div>
</form>

@if (!Model.Stocks.Any())
{
    <p>Няма намерени наличности.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-bordered table-sm align-middle">
            <thead>
                <tr>
                    <th>Код</th>
                    <th>Материал</th>
                    <th>Категория</th>
                    <th>Мерна единица</th>
                    <th>Склад</th>
                    <th>Локация</th>
                    <th>Партида</th>
                    <th>Lot номер</th>
                    <th>Количество</th>
                    <th>Минимална наличност</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stock in Model.Stocks)
                {
                    <tr>
                        <td>@stock.MaterialCode</td>
                        <td>@stock.MaterialName</td>
                        <td>@stock.CategoryName</td>
                        <td>@stock.UnitOfMeasureName</td>
                        <td>@stock.WarehouseName</td>
                        <td>@stock.WarehouseLocationName</td>
                        <td>@stock.BatchNumber</td>
                        <td>@stock.LotNumber</td>
                        <td>@stock.Quantity.ToString("N4")</td>
                        <td>@stock.MinimumStock.ToString("N4")</td>
                        <td><span class="badge @stock.StatusCssClass">@stock.StatusName</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center">
        <div>Общо: @Model.TotalItems</div>
        <div>
            <a class="btn btn-sm btn-outline-secondary @(Model.Filter.Page <= 1 ? "disabled" : string.Empty)"
               asp-controller="StockInquiry"
               asp-action="Index"
               asp-route-Page="@previousPage"
               asp-route-PageSize="@Model.Filter.PageSize"
               asp-route-MaterialId="@Model.Filter.MaterialId"
               asp-route-MaterialCategoryId="@Model.Filter.MaterialCategoryId"
               asp-route-SupplierId="@Model.Filter.SupplierId"
               asp-route-WarehouseId="@Model.Filter.WarehouseId"
               asp-route-WarehouseLocationId="@Model.Filter.WarehouseLocationId"
               asp-route-BatchOrLot="@Model.Filter.BatchOrLot"
               asp-route-LowStockOnly="@Model.Filter.LowStockOnly"
               asp-route-ZeroStockOnly="@Model.Filter.ZeroStockOnly"
               asp-route-ActiveMaterialsOnly="@Model.Filter.ActiveMaterialsOnly">Назад</a>
            <span class="mx-2">Страница @Model.Filter.Page от @Model.TotalPages</span>
            <a class="btn btn-sm btn-outline-secondary @(Model.Filter.Page >= Model.TotalPages ? "disabled" : string.Empty)"
               asp-controller="StockInquiry"
               asp-action="Index"
               asp-route-Page="@nextPage"
               asp-route-PageSize="@Model.Filter.PageSize"
               asp-route-MaterialId="@Model.Filter.MaterialId"
               asp-route-MaterialCategoryId="@Model.Filter.MaterialCategoryId"
               asp-route-SupplierId="@Model.Filter.SupplierId"
               asp-route-WarehouseId="@Model.Filter.WarehouseId"
               asp-route-WarehouseLocationId="@Model.Filter.WarehouseLocationId"
               asp-route-BatchOrLot="@Model.Filter.BatchOrLot"
               asp-route-LowStockOnly="@Model.Filter.LowStockOnly"
               asp-route-ZeroStockOnly="@Model.Filter.ZeroStockOnly"
               asp-route-ActiveMaterialsOnly="@Model.Filter.ActiveMaterialsOnly">Напред</a>
        </div>
    </div>
}