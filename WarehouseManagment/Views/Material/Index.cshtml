@model List<Material>

@{
    ViewData["Title"] = "Материали";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Material" asp-action="Create">Нов материал</a>
</div>

@if (!Model.Any())
{
    <p>Няма създадени материали.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Код</th>
                <th>Име</th>
                <th>Категория</th>
                <th>Мярка</th>
                <th>Доставчик</th>
                <th>Стандартна цена</th>
                <th>Мин. наличност</th>
                <th>Партиди</th>
                <th>Активен</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var material in Model)
            {
                <tr>
                    <td>@material.Code</td>
                    <td>@material.Name</td>
                    <td>@material.MaterialCategory?.Name</td>
                    <td>@material.UnitOfMeasure?.Name</td>
                    <td>@material.Supplier?.Name</td>
                    <td>@material.StandardCost</td>
                    <td>@material.MinimumStock</td>
                    <td>@(material.IsBatchTracked ? "Да" : "Не")</td>
                    <td>@(material.IsActive ? "Да" : "Не")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Material" asp-action="Edit" asp-route-id="@material.Id">Редакция</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}