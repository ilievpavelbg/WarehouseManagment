@model MaterialIndexModel

@{
    ViewData["Title"] = "Материали";
    var importWarnings = TempData["MaterialImportWarnings"]?.ToString()?.Split('|', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
    var importErrors = TempData["MaterialImportErrors"]?.ToString()?.Split('|', StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
}

<h1 class="text-center">@ViewData["Title"]</h1>

@if (TempData["MaterialGoodsReceiptMessage"] != null)
{
    <div class="alert alert-success">@TempData["MaterialGoodsReceiptMessage"]</div>
}

@if (TempData["MaterialTransferMessage"] != null)
{
    <div class="alert alert-success">@TempData["MaterialTransferMessage"]</div>
}

@if (TempData["MaterialStockAdjustmentMessage"] != null)
{
    <div class="alert alert-success">@TempData["MaterialStockAdjustmentMessage"]</div>
}

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Material" asp-action="Create">Нов материал</a>
</div>

<form asp-controller="Material" asp-action="Import" method="post" enctype="multipart/form-data" class="mb-3">
    <div class="row align-items-end">
        <div class="col-md-6">
            <label for="excelFile" class="form-label">Импорт от Excel</label>
            <input id="excelFile" name="excelFile" type="file" accept=".xlsx" class="form-control" />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-outline-primary">Импортирай</button>
        </div>
    </div>
</form>

<form asp-controller="Material" asp-action="Index" method="get" class="mb-3">
    <div class="row align-items-end">
        <div class="col-md-3 mb-2">
            <label asp-for="CategoryId" class="form-label">Категория</label>
            <select asp-for="CategoryId" class="form-control">
                <option value="">Всички</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
        <div class="col-md-3 mb-2">
            <label asp-for="SupplierId" class="form-label">Доставчик</label>
            <select asp-for="SupplierId" class="form-control">
                <option value="">Всички</option>
                @foreach (var supplier in Model.Suppliers)
                {
                    <option value="@supplier.Id">@supplier.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2 mb-2">
            <div class="form-check">
                <input asp-for="LowStockOnly" class="form-check-input" />
                <label asp-for="LowStockOnly" class="form-check-label">Под минимум</label>
            </div>
        </div>
        <div class="col-md-2 mb-2">
            <div class="form-check">
                <input asp-for="ActiveOnly" class="form-check-input" />
                <label asp-for="ActiveOnly" class="form-check-label">Само активни</label>
            </div>
        </div>
        <div class="col-md-2 mb-2">
            <button type="submit" class="btn btn-outline-secondary">Филтрирай</button>
        </div>
    </div>
</form>

@if (TempData["MaterialImportCreated"] != null)
{
    <div class="alert alert-info">
        <div>Създадени: @TempData["MaterialImportCreated"]</div>
        <div>Обновени: @TempData["MaterialImportUpdated"]</div>
        <div>Пропуснати: @TempData["MaterialImportSkipped"]</div>
        @if (importWarnings.Any())
        {
            <hr />
            <strong>Предупреждения:</strong>
            <ul class="mb-0">
                @foreach (var warning in importWarnings)
                {
                    <li>@warning</li>
                }
            </ul>
        }
        @if (importErrors.Any())
        {
            <hr />
            <strong>Грешки:</strong>
            <ul class="mb-0">
                @foreach (var error in importErrors)
                {
                    <li>@error</li>
                }
            </ul>
        }
    </div>
}

@if (!Model.Materials.Any())
{
    <p>Няма създадени материали.</p>
}
else
{
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Код</th>
                <th>Име</th>
                <th>Категория</th>
                <th>Доставчик</th>
                <th>Наличност</th>
                <th>Мерна единица</th>
                <th>Стандартна цена</th>
                <th>Мин. наличност</th>
                <th>Партиди</th>
                <th>Активен</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var material in Model.Materials)
            {
                <tr>
                    <td>@material.Code</td>
                    <td>@material.Name</td>
                    <td>@material.CategoryName</td>
                    <td>@material.SupplierName</td>
                    <td>@material.CurrentStock.ToString("N4") @material.UnitOfMeasureName</td>
                    <td>@material.UnitOfMeasureName</td>
                    <td>@material.StandardCost.ToString("N4")</td>
                    <td>@material.MinimumStock.ToString("N4")</td>
                    <td>@(material.IsBatchTracked ? "Да" : "Не")</td>
                    <td>@(material.IsActive ? "Да" : "Не")</td>
                    <td>
                        <a class="btn btn-sm btn-outline-info" asp-controller="MaterialStockCard" asp-action="Index" asp-route-id="@material.Id">Картон</a>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Material" asp-action="Edit" asp-route-id="@material.Id">Редакция</a>
                        <a class="btn btn-sm btn-primary" asp-controller="Material" asp-action="Receive" asp-route-id="@material.Id">Приемане</a>
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Material" asp-action="Transfer" asp-route-id="@material.Id">Преместване</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-controller="Material" asp-action="AdjustStock" asp-route-id="@material.Id">Корекция наличност</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}